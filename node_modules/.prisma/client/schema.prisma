generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model commentaires {
  id_commentaire      Int          @id @default(autoincrement())
  date_commentaire    DateTime     @db.Date
  note_commentaire    Int
  contenu_commentaire String?      @db.VarChar(500)
  id_utilisateur      Int
  id_recette          Int
  recette             recette      @relation(fields: [id_recette], references: [id_recette], onDelete: Cascade, map: "fk_commentaires_recette")
  utilisateurs        utilisateurs @relation(fields: [id_utilisateur], references: [id_utilisateur], onDelete: Cascade, map: "fk_commentaires_utilisateur")

  @@index([id_recette], map: "fk_commentaires_recette")
  @@index([id_utilisateur], map: "fk_commentaires_utilisateur")
}

model ingredients {
  id_ingredient       Int                   @id @default(autoincrement())
  nom_ingredient      String                @unique(map: "nom_ingredient") @db.VarChar(20)
  recette_ingredients recette_ingredients[]
}

model mots_cles {
  id_mots_cles      Int                 @id @default(autoincrement())
  nom_mot_cle       String              @unique(map: "nom_mot_cle") @db.VarChar(20)
  recette_mots_cles recette_mots_cles[]
}

model recette {
  id_recette          Int                   @id @default(autoincrement())
  nom_recette         String                @db.VarChar(30)
  image_recette       String                @unique(map: "image_recette") @db.VarChar(255)
  heures              Int
  nombre_personnes    Int
  instructions        String                @db.Text
  minutes             Int
  date_ajout_recette  DateTime              @db.Date
  id_utilisateur      Int?
  commentaires        commentaires[]
  utilisateurs        utilisateurs?         @relation(fields: [id_utilisateur], references: [id_utilisateur], map: "fk_recette_utilisateur")
  recette_favoris     recette_favoris[]
  recette_ingredients recette_ingredients[]
  recette_mots_cles   recette_mots_cles[]

  @@index([id_utilisateur], map: "fk_recette_utilisateur")
}

model recette_favoris {
  id_recette     Int
  id_utilisateur Int
  recette        recette      @relation(fields: [id_recette], references: [id_recette], onDelete: Cascade, map: "fk_favoris_recette")
  utilisateurs   utilisateurs @relation(fields: [id_utilisateur], references: [id_utilisateur], onDelete: Cascade, map: "fk_favoris_utilisateur")

  @@id([id_recette, id_utilisateur])
  @@index([id_utilisateur], map: "fk_favoris_utilisateur")
}

model recette_ingredients {
  id_recette    Int
  id_ingredient Int
  ingredients   ingredients @relation(fields: [id_ingredient], references: [id_ingredient], onDelete: Cascade, map: "fk_r_i_ingredient")
  recette       recette     @relation(fields: [id_recette], references: [id_recette], onDelete: Cascade, map: "fk_r_i_recette")

  @@id([id_recette, id_ingredient])
  @@index([id_ingredient], map: "fk_r_i_ingredient")
}

model recette_mots_cles {
  id_recette   Int
  id_mots_cles Int
  mots_cles    mots_cles @relation(fields: [id_mots_cles], references: [id_mots_cles], onDelete: Cascade, map: "fk_r_m_motcle")
  recette      recette   @relation(fields: [id_recette], references: [id_recette], onDelete: Cascade, map: "fk_r_m_recette")

  @@id([id_recette, id_mots_cles])
  @@index([id_mots_cles], map: "fk_r_m_motcle")
}

model utilisateurs {
  id_utilisateur           Int               @id @default(autoincrement())
  nom_utilisateur          String            @db.VarChar(50)
  prenom_utilisateur       String            @db.VarChar(50)
  email_utilisateur        String            @unique(map: "email_utilisateur") @db.VarChar(150)
  mot_de_passe_utilisateur String            @unique(map: "mot_de_passe_utilisateur") @db.VarChar(255)
  commentaires             commentaires[]
  recette                  recette[]
  recette_favoris          recette_favoris[]
}
